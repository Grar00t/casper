{
    "chat.permissions.default": "autopilot",
    "markdown.validate.enabled": true,
    "dotnetAcquisitionExtension.allowInvalidPaths": true,
    "dotnetAcquisitionExtension.enablePreviewFeatures": true,
    "dotnet.inlayHints.enableInlayHintsForIndexerParameters": true,
    "dotnet.inlayHints.enableInlayHintsForObjectCreationParameters": true,
    "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
    "dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
    "dotnet.automaticallySyncWithActiveItem": true,
    "dotnet.debug.suppressInvalidDebugTypeWarning": true,
    "dotnet.preferVisualStudioCodeFileSystemWatcher": true,
    "dotnet.suppressSdkInstallView": true,
    "dotnet.testWindow.disableAutoDiscovery": false,
    "csharp.suppressDotnetInstallWarning": true,
    "dotnet.server.useOmnisharp": true,
    "notebook.defaultFormatter": "ms-dotnettools.csharp",
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.defaultFoldingRangeProvider": "ms-vscode.cpptools-extension-pack",
    "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchArgumentName": true,
    "dotnet.formatting.organizeImportsOnFormat": true,
    "dotnetAcquisitionExtension.highVerbosity": true,
    "dotnet.inlayHints.suppressInlayHintsForParametersThatDifferOnlyBySuffix": true,
    "dotnet.server.suppressLspErrorToasts": true,
    "dotnet.server.waitForDebugger": true,
    "dotnet.testWindow.disableBuildOnRefresh": true,
    "dotnet.testWindow.disableBuildOnRun": true,
    "dotnet.projectsystem.cacheInProjectFolder": true,
    "dotnet.server.suppressMiscellaneousFilesToasts": true,
    "dotnetAcquisitionExtension.showResetDataCommand": true
}